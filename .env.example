# Example environment variables for Go Base App
# Copy this file to .env and modify as needed

# Application
APP_NAME=go-base-app
APP_VERSION=dev
APP_ENVIRONMENT=development
APP_DEBUG=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s
SERVER_GRACEFUL_STOP=10s

# Database
DB_DRIVER=sqlite
DB_DSN=./data/app.db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m
DB_AUTO_MIGRATE=true

# Security
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
CORS_ALLOW_ORIGINS=*
ENABLE_HTTPS=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_STRUCTURED=true

# Features
FEATURE_METRICS=true
FEATURE_TRACING=false
FEATURE_PROFILING=false
FEATURE_SWAGGER=true
FEATURE_HEALTHZ=true
FEATURE_PLAYGROUND=false